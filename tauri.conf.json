{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipType",
  "version": "0.1.0",
  "identifier": "com.xavierwang.cliptype",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ClipType",
        "width": 760,
        "height": 680,
        "minWidth": 560,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "category": "Utility"
  }
}
